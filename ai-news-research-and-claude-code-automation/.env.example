# AI News Research - Environment Variables
# Copy this file to .env and fill in your values

# Hacker News API (no key needed, public API)
HN_API_BASE=https://hacker-news.firebaseio.com/v0

# X/Twitter API (future integration)
# X_BEARER_TOKEN=your_bearer_token_here
# X_API_KEY=your_api_key_here
# X_API_SECRET=your_api_secret_here

# Grok API (future integration)
# GROK_API_KEY=your_grok_api_key_here

# SerpApi (future integration)
# SERPAPI_KEY=your_serpapi_key_here

# Claude API (for summarization, if using directly)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Output settings
MAX_X_DRAFTS=30
DEFAULT_LANGUAGE=ja
