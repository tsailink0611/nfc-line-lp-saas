# ===========================================
# NFC x LINE x LP 営業支援SaaS — 環境変数
# ===========================================
# このファイルをコピーして .env.local を作成:
#   cp .env.local.example .env.local

# -------------------------------------------
# Supabase（必須）
# -------------------------------------------
# Supabase ダッシュボード > Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key

# service_role キー（super admin のアカウント発行に必須）
# ダッシュボード > Settings > API > service_role key
# ※ クライアントに公開しないこと
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key

# -------------------------------------------
# サイトURL（必須）
# -------------------------------------------
# NFC リダイレクトやOGP生成で使用
# ローカル開発: http://localhost:3000
# 本番: https://your-domain.workers.dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -------------------------------------------
# n8n ワークフロー連携（必須）
# -------------------------------------------
# NFC タップ時に n8n webhook を発火するための base URL
# 例: http://[VPS_PUBLIC_IP]:5678
N8N_WEBHOOK_BASE_URL=http://your-n8n-host:5678

# Claude Code CLI から n8n MCP を使う場合に設定
# .mcp.json の ${N8N_MCP_TOKEN} で参照される
N8N_MCP_TOKEN=your-n8n-mcp-token

# -------------------------------------------
# PostHog（任意：行動ログ分析）
# -------------------------------------------
# https://app.posthog.com > Project Settings > API Keys
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
